{
  "expo": {
    "name": "dadHealth",
    "slug": "dadhealth-mobile",
    "version": "1.0.0",
    "scheme": "dadhealth",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0A0A0A",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.uk.dadhealth",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "co.uk.dadhealth"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Dad Health to use Face ID to log you in."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication"
    ]
  }
}
